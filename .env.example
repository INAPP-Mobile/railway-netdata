# Netdata Configuration for Railway
# Copy this file to .env and adjust values as needed.

# Port Netdata listens on (default: 19999)
NETDATA_PORT=19999

# Netdata process group ID (default: 1000)
PGID=1000

# Docker group ID for container monitoring (default: 1000)
DOCKER_GROUP_ID=1000

# Netdata claim token (optional) — for connecting to Netdata Cloud
# Leave empty if not using Netdata Cloud.
# NETDATA_CLAIM_TOKEN=

# Netdata claim URL (optional)
# NETDATA_CLAIM_URL=https://app.netdata.cloud
